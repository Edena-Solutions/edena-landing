---
import { isLegalSectionTitle } from "@/lib/legal-content.ts";

interface Props {
    content: string;
}

const { content } = Astro.props;
const paragraphs = content.split("<br>");
---

<div class="space-y-6 text-base leading-relaxed">
    {
        paragraphs.map((p) =>
            p.trim() ? (
                <p class={isLegalSectionTitle(p) ? "font-bold" : undefined}>{p}</p>
            ) : null
        )
    }
</div>
