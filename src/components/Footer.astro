---
import { cn } from "@/lib/utils";
import { Image } from "astro:assets";
import logo from "@/assets/img/logos/logo.png";
import { translations, localePath } from "@/i18n/index.ts";
import LanguageSwitcher from "./LanguageSwitcher";
interface LinkGroup {
    title: string;
    links: {
        title: string;
        href: string;
    }[];
}

interface Props {
    className?: string;
    lang: string;
}

const { lang, className } = Astro.props;
const t = translations[lang as keyof typeof translations];
// Canonical locale paths: Spanish lives unprefixed at the root.
const p = (path: string) => localePath(lang, path);

const footerGroups: LinkGroup[] = [
    {
        title: t.navigation.products,
        links: [
            { title: t.navigation.crm, href: p("/crm") },
            { title: t.navigation.app, href: p("/app") },
            { title: t.navigation.finance, href: p("/finance") },
            { title: t.productModules.extracurricular.navTitle, href: p("/extracurricular") },
            { title: t.productModules.communication.navTitle, href: p("/communication") },
            {
                title: t.productModules.internalPayments.navTitle,
                href: p("/internal-payments"),
            },
            { title: t.productModules.shop.navTitle, href: p("/shop") },
            { title: t.productModules.tracking.navTitle, href: p("/tracking") },
            { title: t.productModules.workflows.navTitle, href: p("/workflows") },
            { title: t.productModules.ena.navTitle, href: p("/ena") },
        ],
    },
    {
        title: t.navigation.functionalities,
        links: [
            { title: t.navigation.students, href: p("/students") },
            { title: t.navigation.dashboard, href: p("/dashboard") },
            { title: t.navigation.assignment, href: p("/assignment") },
            { title: t.navigation.nurseries, href: p("/nurseries") },
            { title: t.navigation.schools, href: p("/schools") },
            { title: t.navigation.academies, href: p("/academies") },
            { title: t.navigation.groups, href: p("/groups") },
            { title: t.navigation.forFamilies, href: p("/families") },
        ],
    },
    {
        title: t.footer.legal,
        links: [
            { title: t.footer.privacyPolicy, href: p("/privacy") },
            { title: t.footer.termsOfService, href: p("/terms") },
            { title: t.footer.cookiePolicy, href: p("/cookies") },
            { title: t.footer.dpa, href: p("/data-processing") },
            { title: t.footer.deleteAccount, href: p("/delete-account") },
        ],
    },
];

const currentYear = new Date().getFullYear();
---

<footer class={cn("mt-[16px] bg-card", className)}>
    <div class="container mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div
                class="col-span-1 md:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-2 text-center md:text-left"
            >
                {
                    footerGroups.map((group) => (
                        <div class="space-y-4">
                            <h3 class="text-sm">{group.title}</h3>
                            <ul>
                                {group.links.map((link) => (
                                    <li>
                                        <a
                                            href={link.href}
                                            class="text-sm text-muted-foreground hover:text-primary transition-colors"
                                        >
                                            {link.title}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </div>

            <div
                class="md:col-span-1 text-center md:text-left order-first md:order-last mt-8 md:mt-0"
            >
                <a href={p("/")} class="inline-block mb-2">
                    <Image src={logo} alt={t.altText.logo} class="h-6 w-auto dark:invert" />
                </a>
                <p class="text-muted-foreground mb-6 text-sm">
                    {t.footer.description}
                </p>
            </div>
        </div>

        <div class="pt-8 flex flex-col-reverse md:flex-row justify-between gap-4 items-center">
            <p class="text-sm text-muted-foreground text-center md:text-left">
                &copy; {currentYear} Edena Software S.L. {t.footer.allRightsReserved}
            </p>

            <div class="text-center md:text-left flex flex-col sm:flex-row items-center gap-6">
                <a href={p("/blog/")} class="text-sm text-muted-foreground hover:text-primary"
                    >{t.navigation.blog}</a
                >
                <a
                    href={p("/pricing")}
                    class="text-sm text-muted-foreground hover:text-primary"
                    >{t.navigation.pricing}</a
                >
                <a href={p("/faqs")} class="text-sm text-muted-foreground hover:text-primary"
                    >{t.navigation.faqs}</a
                >
                <LanguageSwitcher client:load currentLang={lang} />
            </div>
        </div>
    </div>
</footer>
