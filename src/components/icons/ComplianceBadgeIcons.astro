---
import { Image } from "astro:assets";
import gdpr from "@/assets/img/certifications/gdpr.svg";

export type ComplianceBadgeId = "gdpr";

interface Props {
    id: ComplianceBadgeId;
    class?: string;
}

const { id, class: className = "h-14 w-auto max-h-14 object-contain" } = Astro.props;

const svgAssets = {
    gdpr,
} as const;
---

{
    (
        <Image
            src={svgAssets[id]}
            alt=""
            class={className}
            aria-hidden="true"
            loading="lazy"
            decoding="async"
        />
    )
}
