---
import { Button } from "@/components/ui/button";
import type { Translation } from "@/i18n";
import { getLanguageFromURL, localizedDemoPath } from "@/i18n";

interface Props {
    t: Translation;
    variant?: "default" | "secondary" | "outline" | "ghost" | "link" | "destructive" | "white";
    className?: string;
}

const { t, variant = "default", className = "" } = Astro.props;
const demoUrl = localizedDemoPath(getLanguageFromURL(Astro.url.pathname));
---

<a href={demoUrl}>
    <Button variant={variant} className={className}>
        {t.bookDemo}
    </Button>
</a>
