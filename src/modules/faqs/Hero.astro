---
import type { Translation } from "@/i18n";

interface Props {
    t: Translation;
}

const { t } = Astro.props;
---

<div class="text-center flex flex-col gap-6 items-center pt-16">
    <h1 class="text-xl font-bold">{t.faqs.title}</h1>
    <p class="max-w-xl text-muted-foreground">{t.faqs.description}</p>
</div>
