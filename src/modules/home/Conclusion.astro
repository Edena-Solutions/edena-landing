---
import { Image } from "astro:assets";
import favicon from "@/assets/img/logos/logo-small.svg";
import BookDemoButton from "@/components/BookDemoButton.astro";
import ThemedImage from "@/components/ThemedImage.astro";
import desktopScreenshot from "@/assets/img/screenshots/finance/invoice_analytics.png";
import desktopScreenshotDark from "@/assets/img/screenshots/finance/dark/invoice_analytics.png";
import mobileScreenshot from "@/assets/img/screenshots/app/app_students.png";
import { translations } from "@/i18n/index.ts";
import { cn } from "@/lib/utils";
import Link from "@/components/ui/link";
import { Button } from "@/components/ui/button";

const { lang, isSimplified = false } = Astro.props;
const t = translations[lang as keyof typeof translations];
---

<div class={cn("w-full", !isSimplified && "px-4")}>
    <section
        class="relative mx-auto w-full max-w-7xl overflow-hidden rounded bg-gradient-primary text-white"
    >
        <div
            class="relative z-10 flex flex-col items-center gap-6 px-6 pt-12 pb-0 text-center md:gap-8 md:pt-16 md:px-10"
        >
            <div class="rounded p-1 bg-white">
                <Image src={favicon} alt={t.altText.conclusionLogo} class="h-10 w-10 ml-[1px]" />
            </div>

            <div class="flex max-w-3xl flex-col gap-4">
                <h2
                    class={cn(
                        "text-xl sm:text-3xl font-bold text-white max-w-lg sm:max-w-2xl text-center mx-auto",
                        isSimplified && "sm:text-xl max-w-sm sm:max-w-sm",
                    )}
                >
                    {t.conclusion.title}
                </h2>
                {
                    !isSimplified && (
                        <p class="mx-auto max-w-2xl text-sm leading-relaxed text-white/85 md:text-base">
                            {t.conclusion.description}
                        </p>
                    )
                }
            </div>
            <div class="flex gap-2 items-center justify-center">
                <BookDemoButton t={t} variant="secondary" />
                <Link href="https://stg.edena.es/register-organization">
                    <Button>{t.registerButton}</Button>
                </Link>
            </div>
        </div>

        <div class="relative z-10 mx-auto mt-8 w-full max-w-5xl md:mt-10">
            <!-- Mobile: centered phone screenshot, clipped at bottom -->
            <div class="relative flex h-[300px] justify-center overflow-hidden md:hidden">
                <div class="w-[260px] shrink-0 translate-y-[12%]">
                    <Image
                        src={mobileScreenshot}
                        alt={t.altText.appHero}
                        class="aspect-[9/19] w-full object-cover object-top rounded-t-lg shadow-[0_24px_80px_rgba(0,0,0,0.35)] dark:shadow-[0_24px_80px_rgba(0,0,0,0.6)]"
                        loading="lazy"
                    />
                </div>
            </div>

            <!-- Desktop: desktop + phone overlap -->
            <div class="relative hidden h-[380px] w-full md:block lg:h-[440px]">
                <div
                    class="absolute bottom-0 left-1/2 w-[94%] max-w-[860px] -translate-x-1/2 translate-y-[18%]"
                >
                    <ThemedImage
                        src={desktopScreenshot}
                        darkImage={desktopScreenshotDark}
                        alt={t.altText.invoiceAnalytics}
                        loading="lazy"
                        className="w-full rounded object-cover object-top shadow-[0_24px_80px_rgba(0,0,0,0.35)] dark:shadow-[0_24px_80px_rgba(0,0,0,0.6)]"
                    />
                </div>

                <div
                    class="absolute bottom-0 right-[10%] z-20 w-[190px] translate-y-[6%] lg:right-[10%] lg:w-[210px]"
                >
                    <Image
                        src={mobileScreenshot}
                        alt={t.altText.appHero}
                        class="aspect-[9/19] w-full object-cover object-top rounded shadow-[0_24px_80px_rgba(0,0,0,0.35)] dark:shadow-[0_24px_80px_rgba(0,0,0,0.6)]"
                        loading="lazy"
                    />
                </div>
            </div>
        </div>
    </section>
</div>
