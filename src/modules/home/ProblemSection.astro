---
import GSAPSection from "@/components/ui/gsap-section";
import type { Translation } from "@/i18n";

interface Props {
    t: Translation;
}

const { t } = Astro.props;
const { problemSection } = t;

type ImageItem = { src: string; alt: string; bg?: string; imageClass?: string };

const toolLogos: ImageItem[] = [
    {
        src: "https://sinapsis.agency/uploads/images/2026/01/696c9f0aa8cff_c0ca1cb7.png",
        alt: problemSection.cards.tools.items[0],
    },
    {
        src: "https://upload.wikimedia.org/wikipedia/commons/a/a5/Google_Calendar_icon_%282020%29.svg",
        alt: problemSection.cards.tools.items[1],
    },
    {
        src: "https://upload.wikimedia.org/wikipedia/commons/9/9b/Google_Meet_icon_%282020%29.svg",
        alt: problemSection.cards.tools.items[2],
    },
    {
        src: "https://upload.wikimedia.org/wikipedia/commons/thumb/0/07/Microsoft_Office_Teams_%282025%E2%80%93present%29.svg/500px-Microsoft_Office_Teams_%282025%E2%80%93present%29.svg.png",
        alt: problemSection.cards.tools.items[3],
    },
];

const aiLogos: ImageItem[] = [
    {
        src: "https://cdn.worldvectorlogo.com/logos/openai-2.svg",
        alt: problemSection.cards.ai.items[0],
        imageClass: "dark:invert",
    },
    {
        src: "https://cdn.worldvectorlogo.com/logos/claude-logo.svg",
        alt: problemSection.cards.ai.items[1],
    },
    {
        src: "https://static.vecteezy.com/system/resources/previews/055/687/065/non_2x/gemini-google-icon-symbol-logo-free-png.png",
        alt: problemSection.cards.ai.items[2],
    },
    {
        src: "https://upload.wikimedia.org/wikipedia/en/thumb/a/aa/Microsoft_Copilot_Icon.svg/1280px-Microsoft_Copilot_Icon.svg.png",
        alt: problemSection.cards.ai.items[3],
    },
];

const financeLogos: ImageItem[] = [
    {
        src: "https://upload.wikimedia.org/wikipedia/commons/thumb/e/e3/Microsoft_Office_Excel_%282019%E2%80%932025%29.svg/3840px-Microsoft_Office_Excel_%282019%E2%80%932025%29.svg.png",
        alt: problemSection.cards.finance.items[0],
    },
    {
        src: "https://www.neobis.es/wp-content/uploads/2025/04/Sage_Logo.png",
        alt: problemSection.cards.finance.items[1],
    },
    {
        src: "https://davizgonzalez.com/wp-content/uploads/2024/11/holded-logo.webp",
        alt: problemSection.cards.finance.items[2],
    },
    {
        src: "https://upload.wikimedia.org/wikipedia/commons/thumb/5/59/SAP_2011_logo.svg/330px-SAP_2011_logo.svg.png",
        alt: problemSection.cards.finance.items[3],
    },
];

const cards = [
    { ...problemSection.cards.tools, logos: toolLogos },
    { ...problemSection.cards.ai, logos: aiLogos },
    { ...problemSection.cards.finance, logos: financeLogos },
];

const mobileLogos: ImageItem[] = [
    toolLogos[0], // WhatsApp
    toolLogos[1], // Google Calendar
    toolLogos[3], // Microsoft Teams
    aiLogos[0], // ChatGPT
    aiLogos[2], // Gemini
    financeLogos[0], // Excel
    financeLogos[2], // Holded
];

const logosWithLayout = mobileLogos.map((logo, index) => {
    const center = (mobileLogos.length - 1) / 2;
    const distance = index - center;
    const absDistance = Math.abs(distance);

    return {
        ...logo,
        diameter: Math.round(80 - absDistance * 10),
        imageSize: Math.max(18, Math.round(32 - absDistance * 2.5)),
        zIndex: 20 - Math.round(absDistance),
        offsetX: Math.round(distance * 46),
    };
});
---

<GSAPSection client:load>
    <div class="max-w-5xl mx-auto px-6 flex flex-col gap-4 md:gap-12 items-center">
        <div class="flex flex-col gap-4 text-center">
            <h2
                class="text-xl sm:text-3xl font-bold bg-gradient-to-r from-foreground to-foreground/40 bg-clip-text text-transparent max-w-lg sm:max-w-2xl text-center mx-auto"
            >
                {problemSection.title}
            </h2>
            <p class="text-muted-foreground max-w-xl mx-auto hidden md:block">
                {problemSection.description}
            </p>
        </div>

        <div class="md:hidden w-full flex flex-col items-center gap-6">
            <p class="text-sm text-muted-foreground text-center leading-relaxed max-w-sm">
                {problemSection.mobileSummary}
            </p>
            <div
                class="relative w-full h-[5.75rem] max-w-lg mx-auto"
                aria-label={problemSection.mobileSummary}
            >
                {
                    logosWithLayout.map((logo) => (
                        <div
                            class="absolute top-1/2 left-1/2 rounded bg-card flex items-center justify-center shadow-[0_8px_24px_rgba(0,0,0,0.14)] dark:shadow-[0_8px_24px_rgba(0,0,0,0.5)]"
                            style={`width: ${logo.diameter}px; height: ${logo.diameter}px; z-index: ${logo.zIndex}; transform: translate(calc(-50% + ${logo.offsetX}px), -50%);`}
                        >
                            <img
                                src={logo.src}
                                alt={logo.alt}
                                width={logo.imageSize}
                                height={logo.imageSize}
                                loading="lazy"
                                decoding="async"
                                class={`object-contain ${logo.imageClass ?? ""}`}
                                style={`width: ${logo.imageSize}px; height: ${logo.imageSize}px;`}
                            />
                        </div>
                    ))
                }
            </div>
        </div>

        <div class="w-full hidden md:grid md:grid-cols-3 gap-10">
            {
                cards.map((card) => (
                    <div class="flex flex-col gap-6 h-full">
                        <div class="grid grid-cols-2 grid-rows-2 gap-3 w-full">
                            {card.logos.map((logo) => (
                                <div
                                    class={`flex items-center justify-center rounded bg-card p-4 ${logo.bg ?? ""}`}
                                >
                                    <img
                                        src={logo.src}
                                        alt={logo.alt}
                                        width="35"
                                        height="35"
                                        loading="lazy"
                                        decoding="async"
                                        class={`w-8 h-8 object-contain ${logo.imageClass ?? ""}`}
                                    />
                                </div>
                            ))}
                        </div>

                        <div class="flex flex-col gap-2 text-left">
                            <h3 class="font-bold text-[10px] uppercase tracking-widest">
                                {card.title}
                            </h3>
                            <p class="text-sm text-muted-foreground leading-relaxed">
                                <strong class="text-foreground font-semibold">
                                    {card.highlight}
                                </strong>{" "}
                                {card.description}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</GSAPSection>
