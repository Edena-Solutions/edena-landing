---
import { Button } from "@/components/ui/button";
import IntegrationsLogosStack from "@/components/IntegrationsLogosStack.astro";
import GSAPSection from "@/components/ui/gsap-section";
import type { Translation } from "@/i18n";

interface Props {
    t: Translation;
}

const { t } = Astro.props;
const { integrationsSection } = t;
---

<GSAPSection client:load>
    <div class="max-w-5xl mx-auto px-6 flex flex-col gap-6 items-center">
        <div class="flex flex-col gap-4 text-center">
            <h2
                class="text-xl sm:text-3xl font-bold bg-gradient-to-r from-foreground to-foreground/40 bg-clip-text text-transparent max-w-lg sm:max-w-2xl text-center mx-auto"
            >
                {integrationsSection.title}
            </h2>
        </div>

        <p class="text-sm text-muted-foreground text-center leading-relaxed max-w-sm sm:max-w-xl">
            {integrationsSection.description}
        </p>

        <Button>
            {t.knowMore}
        </Button>

        <IntegrationsLogosStack t={t} class="my-10" />
    </div>
</GSAPSection>
