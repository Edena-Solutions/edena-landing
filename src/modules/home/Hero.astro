---
import type { Translation } from "@/i18n";
import { getLanguageFromURL, useTranslatedPath } from "@/i18n";

import { Card, CardHeader, CardContent, CardFooter } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import BookDemoButton from "@/components/BookDemoButton.astro";
import AppAnimation from "@/components/AppAnimation";
import Link from "@/components/ui/link";
import GSAPSection from "@/components/ui/gsap-section";
import ThemedImage from "@/components/ThemedImage.astro";
import heroImage from "@/assets/img/screenshots/shared/hero.png";
import heroImageDark from "@/assets/img/screenshots/shared/dark/hero.png";
import assignmentEvaluation from "@/assets/img/screenshots/assignment/evaluation_cycle.png";
import assignmentEvaluationDark from "@/assets/img/screenshots/assignment/dark/evaluation_cycle.png";

interface Props {
    t: Translation;
}

const { t } = Astro.props;
const lang = getLanguageFromURL(Astro.url.pathname);
const translatePath = useTranslatedPath(lang);
const appUrl = translatePath("/app");
---

<GSAPSection client:load className="grid gap-4" animationType="opacity">
    <Card
        className="flex flex-col items-center justify-start text-center h-90 sm:h-160 overflow-hidden bg-card gap-4"
    >
        <CardHeader>
            <h1 class="text-xl font-bold max-w-2xl">{t.hero.mainTitle}</h1>
        </CardHeader>
        <CardContent>
            <p class="text-muted-foreground max-w-150">
                {t.hero.mainDescription}
            </p>
        </CardContent>
        <CardFooter>
            <ThemedImage
                src={heroImage}
                darkImage={heroImageDark}
                alt={t.altText.heroImage}
                loading="eager"
                className="w-full sm:w-2/3 mx-auto object-contain rounded"
            />
        </CardFooter>
    </Card>

    <div class="grid gap-4 px-4 text-sm sm:grid-cols-2 w-full">
        <Card
            className="flex flex-col items-center gap-6 rounded text-center overflow-visible bg-gradient-primary h-100 md:h-130 overflow-hidden"
        >
            <CardHeader className="flex flex-col items-center gap-4">
                <h3 class="text-xl font-bold">{t.hero.mobileTitle}</h3>
                <p class="max-w-md">{t.hero.mobileDescription}</p>
            </CardHeader>
            <CardFooter className="flex flex-col gap-4 items-center">
                <Link href={appUrl} className="relative z-10">
                    <Button variant="white">
                        {t.knowMore}
                    </Button>
                </Link>
                <AppAnimation
                    client:only="react"
                    className="md:-mt-40 md:min-w-[300px] md:max-w-[300px]"
                />
            </CardFooter>
        </Card>

        <Card
            className="flex flex-col items-center gap-6 rounded bg-card text-center overflow-visible h-100 md:h-130 overflow-hidden"
        >
            <CardHeader className="flex flex-col items-center gap-4">
                <h3 class="text-xl font-bold">{t.hero.orgTitle}</h3>
                <p class="max-w-md text-muted-foreground">{t.hero.orgDescription}</p>
            </CardHeader>
            <CardFooter className="flex flex-col gap-4 items-center">
                <BookDemoButton t={t} />
                <ThemedImage
                    src={assignmentEvaluation}
                    darkImage={assignmentEvaluationDark}
                    alt={t.altText.emailInvoice || t.altText.heroImage}
                    className="w-full xl:w-4/5 mx-auto object-contain rounded"
                />
            </CardFooter>
        </Card>
    </div>
</GSAPSection>
