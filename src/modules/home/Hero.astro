---
import type { Translation } from "@/i18n";
import { getLanguageFromURL, useTranslatedPath } from "@/i18n";

import { Card, CardHeader, CardContent, CardFooter } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import AppAnimation from "@/components/AppAnimation";
import Link from "@/components/ui/link";
import GSAPSection from "@/components/ui/gsap-section";
import TopGlow from "@/components/TopGlow.astro";
import ThemedImage from "@/components/ThemedImage.astro";
import IntegrationsLogosStack from "@/components/IntegrationsLogosStack.astro";
// import TrustedBySection from "@/modules/home/TrustedBySection.astro";
import heroImage from "@/assets/img/screenshots/shared/hero.png";
import heroImageDark from "@/assets/img/screenshots/shared/dark/hero.png";
import BookDemoButton from "@/components/BookDemoButton.astro";

interface Props {
    t: Translation;
}

const { t } = Astro.props;
const { integrationsSection } = t;
const lang = getLanguageFromURL(Astro.url.pathname);
const translatePath = useTranslatedPath(lang);
const appUrl = translatePath("/app");
---

<GSAPSection
    client:load
    className="grid min-w-0 w-full max-w-full gap-4 overflow-hidden"
    animationType="opacity"
>
    <Card
        className="flex flex-col items-center justify-start text-center h-110 sm:h-160 overflow-hidden bg-background gap-4"
    >
        <CardHeader>
            <h1
                class="text-xl sm:text-3xl font-bold bg-gradient-to-r from-foreground to-foreground/40 bg-clip-text text-transparent max-w-lg sm:max-w-2xl text-center mx-auto"
            >
                {t.hero.mainTitle}
            </h1>
        </CardHeader>
        <CardContent>
            <p class="text-muted-foreground max-w-150">
                {t.hero.mainDescription}
            </p>
            <div class="hidden sm:flex flex-col gap-4 items-center justify-center mt-8">
                <div class="flex gap-2 items-center justify-center">
                    <BookDemoButton t={t} variant="secondary" />
                    <Link href="https://app.edena.es/register-organization">
                        <Button>{t.registerButtonExtended}</Button>
                    </Link>
                </div>
                <div>
                    <p class="text-[8px] text-muted-foreground uppercase tracking-wider">
                        {t.noCreditCardRequired}
                    </p>
                </div>
            </div>
        </CardContent>
        <CardFooter>
            <ThemedImage
                src={heroImage}
                darkImage={heroImageDark}
                alt={t.altText.heroImage}
                loading="eager"
                className="w-full sm:w-11/12 min-[960px]:w-3/4 lg:w-2/3 mx-auto object-contain rounded origin-center transition-transform duration-500 ease-out hover:-translate-y-3 hover:scale-[1.07]"
            />
        </CardFooter>
    </Card>

    <div class="grid w-full grid-cols-1 gap-4 px-4 text-sm min-[960px]:grid-cols-2">
        <Card
            className="relative text-white flex flex-col items-center gap-6 rounded text-center overflow-hidden bg-card h-130"
        >
            <TopGlow />
            <CardHeader className="relative z-10 flex flex-col items-center gap-4">
                <h3 class="text-xl font-bold">{t.hero.mobileTitle}</h3>
                <p class="max-w-md">{t.hero.mobileDescription}</p>
            </CardHeader>
            <CardFooter className="relative z-10 flex flex-col gap-4 items-center">
                <AppAnimation
                    client:only="react"
                    knowMoreLabel={t.knowMore}
                    knowMoreHref={appUrl}
                    screenTitles={t.hero.appScreens}
                    className="md:-mt-40 md:min-w-[300px] md:max-w-[300px]"
                />
            </CardFooter>
        </Card>

        <Card
            className="flex flex-col items-center gap-16 rounded bg-card text-center overflow-hidden h-130"
        >
            <CardHeader className="flex flex-col items-center gap-4 pb-0">
                <h3 class="text-xl font-bold">{integrationsSection.title}</h3>
                <p class="max-w-md text-sm text-muted-foreground leading-relaxed">
                    {integrationsSection.description}
                </p>
            </CardHeader>
            <CardFooter className="flex flex-col gap-4 items-center w-full pb-8 pt-2">
                <IntegrationsLogosStack t={t} class="scale-90 sm:scale-100" />
            </CardFooter>
        </Card>
    </div>

    <!-- <TrustedBySection t={t} /> -->
</GSAPSection>
