---
import { translations, languages } from "@/i18n/index.ts";
import Layout from "@/layouts/main.astro";
import Hero from "@/components/Hero.astro";
import Section from "@/components/Section.astro";
import GSAPSection from "@/components/ui/gsap-section";
import Features from "@/components/Features";
import ProductFAQs from "@/components/ProductFAQs.astro";
import SoftwareApplicationSchema from "@/components/StructuredData/SoftwareApplication.astro";
import { ogFromAsset } from "@/lib/og-image";
import calendarImage from "@/assets/img/screenshots/dashboard/dashboard_calendar.png";
import calendarImageDark from "@/assets/img/screenshots/dashboard/dark/dashboard_calendar.png";
import heroImage from "@/assets/img/screenshots/tracking/tracking_hero.png";
import heroImageDark from "@/assets/img/screenshots/tracking/dark/tracking_hero.png";
import trackingImage from "@/assets/img/screenshots/tracking/tracking_template.png";
import trackingImageDark from "@/assets/img/screenshots/tracking/dark/tracking_template.png";
import trackingControlImage from "@/assets/img/screenshots/tracking/tracking_timer.png";
import trackingControlImageDark from "@/assets/img/screenshots/tracking/dark/tracking_timer.png";

export function getStaticPaths() {
    return languages.map((lang) => ({
        params: { lang },
        props: { lang },
    }));
}

const { lang } = Astro.props;
const t = translations[lang as keyof typeof translations];
const m = t.productModules.tracking;

const icons = ["Clock", "CalendarDays", "ListChecks", "UserCheck", "FileBarChart", "Bell"];
const features = m.features.map((f, i) => ({
    icon: icons[i],
    title: f.title,
    description: f.description,
    navigateTo: `/${lang}/tracking`,
}));
---

<Layout
    content={{
        title: m.metaTitle,
        description: m.metaDescription,
        ...ogFromAsset(calendarImage, Astro.site),
    }}
    lang={lang}
>
    <GSAPSection client:load className="grid gap-16" animationType="opacity">
        <Hero
            t={t}
            heroImage={heroImage}
            heroImageDark={heroImageDark}
            showBookDemoInHero={true}
            mainTitle={m.mainTitle}
            mainDescription={m.mainDescription}
            leftCard={{
                title: m.heroLeftTitle,
                description: m.heroLeftDescription,
                showButton: true,
            }}
            rightCard={{
                title: m.heroRightTitle,
                description: m.heroRightDescription,
                image: trackingImage,
                imageDark: trackingImageDark,
                imageClass: "mt-8",
                altText: m.altHero,
            }}
        />
        <Features
            client:load
            t={t}
            features={features}
            title={m.featuresTitle}
            description={m.featuresDescription}
        />
        <Section
            t={t}
            sectionTitle={m.sectionTitle}
            sectionDescription={m.sectionDescription}
            leftCard={{
                title: m.section1Title,
                description: m.section1Description,
                image: trackingControlImage,
                imageDark: trackingControlImageDark,
                imageClass: "w-full mx-auto object-contain md:h-100",
                altText: m.altSection1,
            }}
            rightCard={{
                title: m.section2Title,
                description: m.section2Description,
                image: calendarImage,
                imageDark: calendarImageDark,
                imageClass: "w-full mx-auto object-contain md:h-100",
                altText: m.altSection2,
            }}
        />
        <ProductFAQs t={t} title={m.faqTitle} description={m.faqDescription} faqs={m.faqs} />
    </GSAPSection>
    <SoftwareApplicationSchema
        slot="structured-data"
        name="Edena - Tracking y Control Horario"
        description={m.metaDescription}
        applicationCategory="EducationalApplication"
        operatingSystem={["Web", "iOS", "Android"]}
        url={`https://edena.es/${lang}/tracking`}
        lang={lang}
    />
</Layout>
