---
import { translations, languages } from "@/i18n/index.ts";

import Layout from "@/layouts/main.astro";
import Hero from "@/components/Hero.astro";
import Section from "@/components/Section.astro";
import GSAPSection from "@/components/ui/gsap-section";
import FAQs from "@/modules/groups/FAQs.astro";
import Features from "@/components/Features";
import heroImage from "@/assets/img/screenshots/finance/billing_cycle.png";
import reportingImage from "@/assets/img/screenshots/finance/invoice_analytics.png";
import sharedOrg from "@/assets/img/screenshots/shared/hero.png";
import chatAnimation from "@/assets/animations/chat.json";
import SoftwareApplicationSchema from "@/components/StructuredData/SoftwareApplication.astro";
import FAQPageSchema from "@/components/StructuredData/FAQPage.astro";
import { getCollection } from "astro:content";
import { ogFromAsset } from "@/lib/og-image";

export function getStaticPaths() {
    return languages.map((lang) => ({
        params: { lang },
        props: { lang },
    }));
}

const { lang } = Astro.props;
const t = translations[lang as keyof typeof translations];

const faqsCollection = await getCollection("faqs");
const groupsFaqs = faqsCollection.find((entry) => entry.id === "faqsGroups.md");

const features = [
    {
        icon: "Layers",
        title: t.features.centersFeatures.analyticsDashboard.title,
        description: t.features.centersFeatures.analyticsDashboard.tagline,
        navigateTo: `/${lang}/dashboard`,
    },
    {
        icon: "CreditCard",
        title: t.features.centersFeatures.automatedBilling.title,
        description: t.features.centersFeatures.automatedBilling.tagline,
        navigateTo: `/${lang}/finance`,
    },
    {
        icon: "Zap",
        title: t.features.centersFeatures.processAutomation.title,
        description: t.features.centersFeatures.processAutomation.tagline,
        navigateTo: `/${lang}/dashboard`,
    },
    {
        icon: "MessageCircle",
        title: t.features.centersFeatures.communicationHub.title,
        description: t.features.centersFeatures.communicationHub.tagline,
        navigateTo: `/${lang}/app`,
    },
    {
        icon: "Users",
        title: t.features.centersFeatures.studentManagement.title,
        description: t.features.centersFeatures.studentManagement.tagline,
        navigateTo: `/${lang}/students`,
    },
    {
        icon: "Shield",
        title: t.features.centersFeatures.dataSecurity.title,
        description: t.features.centersFeatures.dataSecurity.tagline,
        navigateTo: `/${lang}/dashboard`,
    },
];
---

<Layout
    content={{
        title: t.meta.groupsTitle,
        description: t.meta.groupsDescription,
        ...ogFromAsset(heroImage, Astro.site),
    }}
    lang={lang}
>
    <GSAPSection client:load className="grid gap-16" animationType="opacity">
        <Hero
            t={t}
            heroImage={heroImage}
            showBookDemoInHero={true}
            mainTitle={t.groups.mainTitle}
            mainDescription={t.groups.mainDescription}
            leftCard={{
                title: t.groups.communicationTitle,
                description: t.groups.communicationDescription,
                showButton: true,
            }}
            rightCard={{
                title: t.groups.automationTitle,
                description: t.groups.automationDescription,
                image: sharedOrg,
                altText: t.altText.organization,
            }}
        />
        <Features
            client:load
            t={t}
            features={features}
            title={t.groups.integratedManagementTitle}
            description={t.groups.integratedManagementDescription}
        />
        <Section
            t={t}
            sectionTitle={t.groups.networkSectionTitle}
            sectionDescription={t.groups.networkSectionDescription}
            leftCard={{
                title: t.groups.realTimeCommunicationTitle,
                description: t.groups.realTimeCommunicationDescription,
                lottie: chatAnimation,
                imageClass: "w-1/3 mx-auto",
                cardClass: "md:h-120 overflow-hidden h-100",
                altText: t.altText.notifications,
            }}
            rightCard={{
                title: t.groups.financialAutomationTitle,
                description: t.groups.financialAutomationDescription,
                image: reportingImage,
                imageClass: "w-full mx-auto",
                cardClass: "h-80 md:h-120 overflow-hidden",
                altText: t.altText.invoiceAnalytics,
            }}
        />
        <FAQs t={t} />
    </GSAPSection>
    <SoftwareApplicationSchema
        slot="structured-data"
        name="Edena - Gestión para Grupos Educativos"
        description={t.meta.groupsDescription}
        applicationCategory="EducationalApplication"
        operatingSystem={["Web", "iOS", "Android"]}
        url={`https://edena.es/${lang}/groups`}
        lang={lang}
    />
    {
        groupsFaqs?.data.faqs && (
            <FAQPageSchema
                slot="structured-data"
                faqs={groupsFaqs.data.faqs}
                translations={t.faqs}
                lang={lang}
            />
        )
    }
</Layout>
