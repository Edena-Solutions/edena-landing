---
import { translations, languages } from "@/i18n/index.ts";
import Layout from "@/layouts/main.astro";
import Hero from "@/components/Hero.astro";
import Section from "@/components/Section.astro";
import GSAPSection from "@/components/ui/gsap-section";
import Features from "@/components/Features";
import ProductFAQs from "@/components/ProductFAQs.astro";
import SoftwareApplicationSchema from "@/components/StructuredData/SoftwareApplication.astro";
import { ogFromAsset } from "@/lib/og-image";
import heroImage from "@/assets/img/screenshots/workflows/workflow_hero.png";
import heroImageDark from "@/assets/img/screenshots/workflows/dark/workflow_hero.png";
import workflowTriggerImage from "@/assets/img/screenshots/workflows/workflow_trigger.png";
import workflowTriggerImageDark from "@/assets/img/screenshots/workflows/dark/workflow_trigger.png";
import workflowActionsImage from "@/assets/img/screenshots/workflows/workflow_actions.png";
import workflowActionsImageDark from "@/assets/img/screenshots/workflows/dark/workflow_actions.png";
import workflowDetailsImage from "@/assets/img/screenshots/workflows/workflow_detail.png";
import workflowDetailsImageDark from "@/assets/img/screenshots/workflows/dark/workflow_detail.png";

export function getStaticPaths() {
    return languages.map((lang) => ({
        params: { lang },
        props: { lang },
    }));
}

const { lang } = Astro.props;
const t = translations[lang as keyof typeof translations];
const m = t.productModules.workflows;

const icons = ["Workflow", "Zap", "Mail", "Receipt", "ListChecks", "LayoutTemplate"];
const features = m.features.map((f, i) => ({
    icon: icons[i],
    title: f.title,
    description: f.description,
    navigateTo: `/${lang}/workflows`,
}));
---

<Layout
    content={{
        title: m.metaTitle,
        description: m.metaDescription,
        ...ogFromAsset(heroImage, Astro.site),
    }}
    lang={lang}
>
    <GSAPSection client:load className="grid gap-16" animationType="opacity">
        <Hero
            t={t}
            heroImage={heroImage}
            heroImageDark={heroImageDark}
            showBookDemoInHero={true}
            mainTitle={m.mainTitle}
            mainDescription={m.mainDescription}
            leftCard={{
                title: m.heroLeftTitle,
                description: m.heroLeftDescription,
                showButton: true,
            }}
            rightCard={{
                title: m.heroRightTitle,
                description: m.heroRightDescription,
                image: workflowTriggerImage,
                imageDark: workflowTriggerImageDark,
                imageClass: "w-1/3 md:w-full mx-auto object-contain md:h-100",
                altText: m.altHero,
            }}
        />
        <Features
            client:load
            t={t}
            features={features}
            title={m.featuresTitle}
            description={m.featuresDescription}
        />
        <Section
            t={t}
            sectionTitle={m.sectionTitle}
            sectionDescription={m.sectionDescription}
            leftCard={{
                title: m.section1Title,
                description: m.section1Description,
                image: workflowActionsImage,
                imageDark: workflowActionsImageDark,
                imageClass: "w-1/2 md:w-full mx-auto object-contain md:h-100",
                altText: m.altSection1,
            }}
            rightCard={{
                title: m.section2Title,
                description: m.section2Description,
                image: workflowDetailsImage,
                imageDark: workflowDetailsImageDark,
                imageClass: "w-full mx-auto object-contain",
                altText: m.altSection2,
            }}
        />
        <ProductFAQs t={t} title={m.faqTitle} description={m.faqDescription} faqs={m.faqs} />
    </GSAPSection>
    <SoftwareApplicationSchema
        slot="structured-data"
        name="Edena - Workflows"
        description={m.metaDescription}
        applicationCategory="EducationalApplication"
        operatingSystem={["Web", "iOS", "Android"]}
        url={`https://edena.es/${lang}/workflows`}
        lang={lang}
    />
</Layout>
