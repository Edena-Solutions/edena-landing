---
import { getEntry, getCollection } from "astro:content";
import Layout from "@/layouts/main.astro";
import { translations } from "@/i18n/index.ts";
import { ChevronLeft } from "lucide-react";
import TableOfContents from "@/components/TableOfContents";
import ArticleSchema from "@/components/StructuredData/Article.astro";
import BreadcrumbListSchema from "@/components/StructuredData/BreadcrumbList.astro";
import Link from "@/components/ui/link";
import { Button } from "@/components/ui/button";
import { ogFromAsset } from "@/lib/og-image";
import defaultBlogOg from "@/assets/img/screenshots/shared/hero.png";

export async function getStaticPaths() {
    const postsEs = await getCollection("blogEs");
    const postsEn = await getCollection("blogEn");
    const postsCa = await getCollection("blogCa");

    const pathsEs = postsEs.map((post) => ({
        params: { lang: "es", slug: post.slug },
        props: { lang: "es", slug: post.slug },
    }));

    const pathsEn = postsEn.map((post) => ({
        params: { lang: "en", slug: post.slug },
        props: { lang: "en", slug: post.slug },
    }));

    const pathsCa = postsCa.map((post) => ({
        params: { lang: "ca", slug: post.slug },
        props: { lang: "ca", slug: post.slug },
    }));

    const postsEus = await getCollection("blogEus");
    const pathsEus = postsEus.map((post) => ({
        params: { lang: "eus", slug: post.slug },
        props: { lang: "eus", slug: post.slug },
    }));

    const pathsFr = postsEn.map((post) => ({
        params: { lang: "fr", slug: post.slug },
        props: { lang: "fr", slug: post.slug },
    }));

    return [...pathsEs, ...pathsEn, ...pathsCa, ...pathsEus, ...pathsFr];
}

const { lang, slug } = Astro.props;
const t = translations[lang as keyof typeof translations];
const collectionName =
    lang === "en"
        ? "blogEn"
        : lang === "fr"
          ? "blogEn"
          : lang === "ca"
            ? "blogCa"
            : lang === "eus"
              ? "blogEus"
              : "blogEs";
const post = await getEntry(collectionName, slug);
if (!post) throw new Error("Post not found");
const { Content } = await post.render();

const postUrl = `https://edena.es/${lang}/blog/${slug}`;
const blogUrl = `https://edena.es/${lang}/blog`;
const homeUrl = `https://edena.es/${lang === "es" ? "" : `${lang}/`}`;

const publishedDate = new Date(post.data.date).toISOString();
const ogMeta = post.data.cover
    ? { ogImage: post.data.cover, ogImageWidth: "1200", ogImageHeight: "630" }
    : ogFromAsset(defaultBlogOg, Astro.site);
---

<Layout
    content={{
        title: post.data.title,
        description: post.data.description,
        ...ogMeta,
        articleAuthor: post.data.author || "Edena Team",
        articlePublishedTime: publishedDate,
    }}
    lang={lang}
>
    <div class="max-w-7xl mx-auto py-6 px-4">
        <Link href={`/${lang}/blog/`} className="text-sm flex items-center gap-2">
            <ChevronLeft className="w-4 h-4" />
            {t.navigation.blog}
        </Link>

        <div class="lg:hidden mb-6">
            <TableOfContents client:load variant="mobile" />
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 sm:mt-6">
            <div class="hidden lg:block lg:col-span-1">
                <TableOfContents client:load variant="sidebar" />
            </div>

            <article class="lg:col-span-3">
                <h1 class="text-xl font-bold mb-2">{post.data.title}</h1>
                <p class="text-muted-foreground text-sm mb-6">
                    {
                        new Date(post.data.date).toLocaleDateString(lang, {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        })
                    }
                </p>
                {
                    post.data.cover && (
                        <img
                            src={post.data.cover}
                            alt={post.data.title}
                            class="mb-6 rounded w-full max-h-80 object-cover"
                        />
                    )
                }
                <div class="prose prose-neutral max-w-none blog-content">
                    <Content />
                </div>

                <div
                    class="bg-gradient-primary mt-8 rounded px-8 py-10 md:px-14 md:py-14 flex flex-col items-center text-center gap-6"
                >
                    <div class="flex flex-col items-center gap-3 text-white">
                        <h2 class="text-xl md:text-2xl font-bold max-w-xl">
                            {t.blog.ctaTitle}
                        </h2>
                        <p class="max-w-lg text-sm md:text-base">
                            {t.blog.ctaDescription}
                        </p>
                    </div>
                    <Link href={`/${lang}/demo`}>
                        <Button variant="white">
                            {t.bookDemo}
                        </Button>
                    </Link>
                </div>
            </article>
        </div>
    </div>
    <ArticleSchema
        slot="structured-data"
        title={post.data.title}
        description={post.data.description}
        date={post.data.date}
        author={post.data.author}
        cover={post.data.cover}
        url={postUrl}
        lang={lang}
    />
    <BreadcrumbListSchema
        slot="structured-data"
        items={[
            {
                name:
                    lang === "es"
                        ? "Inicio"
                        : lang === "ca"
                          ? "Inici"
                          : lang === "eus"
                            ? "Hasiera"
                            : lang === "fr"
                              ? "Accueil"
                              : "Home",
                url: homeUrl,
            },
            { name: t.navigation.blog, url: blogUrl },
            { name: post.data.title, url: postUrl },
        ]}
        lang={lang}
    />
</Layout>
