---
import { translations, localeStaticPaths, localePath } from "@/i18n/index.ts";

import Layout from "@/layouts/main.astro";
import Section from "@/components/Section.astro";
import Hero from "@/components/Hero.astro";
import GSAPSection from "@/components/ui/gsap-section";
import FAQs from "@/modules/finance/FAQs.astro";
import ProductFAQs from "@/components/ProductFAQs.astro";
import Features from "@/components/Features";
import heroImage from "@/assets/img/screenshots/finance/billing_info.png";
import heroImageDark from "@/assets/img/screenshots/finance/dark/billing_info.png";
import billingCycle from "@/assets/img/screenshots/finance/billing_cycle.png";
import billingCycleDark from "@/assets/img/screenshots/finance/dark/billing_cycle.png";
import invoiceAnalytics from "@/assets/img/screenshots/finance/invoice_analytics.png";
import invoiceDetail from "@/assets/img/screenshots/invoice/invoice_detail.png";
import invoiceAnalyticsDark from "@/assets/img/screenshots/finance/dark/invoice_analytics.png";
import invoiceDetailDark from "@/assets/img/screenshots/invoice/dark/invoice_detail.png";
import SoftwareApplicationSchema from "@/components/StructuredData/SoftwareApplication.astro";
import FAQPageSchema from "@/components/StructuredData/FAQPage.astro";
import { getCollection } from "astro:content";

export function getStaticPaths() {
    return localeStaticPaths();
}

const { lang } = Astro.props;
const t = translations[lang as keyof typeof translations];

const faqsCollection = await getCollection("faqs");
const financeFaqs = faqsCollection.find((entry) => entry.id === "faqsFinance.md");

const features = [
    {
        icon: "Receipt",
        title: t.features.financeFeatures.automatedBilling.title,
        description: t.features.financeFeatures.automatedBilling.tagline,
        navigateTo: localePath(lang, "/workflows"),
    },
    {
        icon: "CreditCard",
        title: t.features.financeFeatures.paymentProcessing.title,
        description: t.features.financeFeatures.paymentProcessing.tagline,
        navigateTo: localePath(lang, "/internal-payments"),
    },
    {
        icon: "PieChart",
        title: t.features.financeFeatures.budgetManagement.title,
        description: t.features.financeFeatures.budgetManagement.tagline,
        navigateTo: localePath(lang, "/dashboard"),
    },
    {
        icon: "GraduationCap",
        title: t.features.financeFeatures.scholarshipManagement.title,
        description: t.features.financeFeatures.scholarshipManagement.tagline,
        navigateTo: localePath(lang, "/students"),
    },
    {
        icon: "FileBarChart",
        title: t.features.financeFeatures.financialReporting.title,
        description: t.features.financeFeatures.financialReporting.tagline,
        navigateTo: localePath(lang, "/dashboard"),
    },
    {
        icon: "Calculator",
        title: t.features.financeFeatures.costAnalysis.title,
        description: t.features.financeFeatures.costAnalysis.tagline,
        navigateTo: localePath(lang, "/dashboard"),
    },
];
---

<Layout
    content={{ title: t.meta.financeTitle, description: t.meta.financeDescription }}
    lang={lang}
>
    <GSAPSection client:load className="grid gap-16" animationType="opacity">
        <Hero
            t={t}
            heroImage={heroImage}
            heroImageDark={heroImageDark}
            mainTitle={t.finance.mainTitle}
            mainDescription={t.finance.mainDescription}
            showBookDemoInHero={true}
            leftCard={{
                title: t.finance.fastBillingTitle,
                description: t.finance.fastBillingDescription,
                showButton: true,
            }}
            rightCard={{
                title: t.finance.billingCycleTitle,
                description: t.finance.billingCycleDescription,
                image: billingCycle,
                imageDark: billingCycleDark,
                altText: t.altText.billingCycle,
            }}
        />
        <Features
            client:load
            t={t}
            features={features}
            title={t.features.financeFeatures.title}
            description={t.features.financeFeatures.tagline}
        />
        <Section
            t={t}
            sectionTitle={t.finance.automationTitle}
            sectionDescription={t.finance.automationDescription}
            leftCard={{
                title: t.finance.analyticsTitle,
                description: t.finance.analyticsDescription,
                image: invoiceAnalytics,
                imageDark: invoiceAnalyticsDark,
                altText: t.altText.invoiceAnalytics,
            }}
            rightCard={{
                title: t.finance.paperlessBillingTitle,
                description: t.finance.paperlessBillingDescription,
                image: invoiceDetail,
                imageDark: invoiceDetailDark,
                altText: t.altText.emailInvoice,
            }}
        />
        <ProductFAQs
            t={t}
            title={t.verifactuSection.title}
            description={t.verifactuSection.description}
            faqs={t.verifactuSection.faqs}
        />
        <FAQs t={t} />
    </GSAPSection>
    <SoftwareApplicationSchema
        slot="structured-data"
        name="Edena - Suite Financiera"
        description={t.meta.financeDescription}
        applicationCategory="EducationalApplication"
        operatingSystem={["Web", "iOS", "Android"]}
        url={`https://edena.es/${lang}/finance`}
        lang={lang}
    />
    {
        /* Single FAQPage block per page: collection FAQs + literal Verifactu FAQs
           (FAQPage.astro falls back to the literal string when a key is missing). */
        financeFaqs?.data.faqs && (
            <FAQPageSchema
                slot="structured-data"
                faqs={[...financeFaqs.data.faqs, ...t.verifactuSection.faqs]}
                translations={t.faqs}
                lang={lang}
            />
        )
    }
</Layout>
